{
  "schemaVersion": 1,
  "id": "sow",
  "version": "${version}",
  "name": "Songs Of War",
  "description": "The Songs of War Animation Mod",
  "authors": [
    "IAFEnvoy",
    "HF_ColdWind",
    "Sildarflame"
  ],
  "contact": {
    "sources": "https://github.com/CodeOfArdonia/SongsOfWar"
  },
  "license": "All Rights Reserved",
  "icon": "logo_2.jpg",
  "environment": "*",
  "entrypoints": {
